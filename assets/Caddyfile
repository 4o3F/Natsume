        reverse_proxy http://localhost {
            header_up X-DOMjudge-Login "test_team"
            header_up X-DOMjudge-Pass "dGVzdEBwYXNzd29yZA=="
        }
    }

    handle {
        reverse_proxy http://localhost
    }
}